# Supabase project: https://qgawmjczgfbhwsdpsqly.supabase.co

# Supabase (project dashboard → Connect)
NEXT_PUBLIC_SUPABASE_URL=https://qgawmjczgfbhwsdpsqly.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only: used by import scripts and server actions (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Telegram Mini App (server-only — never expose to browser)
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Random secret for deriving Supabase passwords: openssl rand -hex 32
TELEGRAM_AUTH_PEPPER=your-random-pepper-here

# Dev only: auto sign-in when opened outside Telegram (defaults to 169900085)
DEV_TELEGRAM_ID=169900085

# Public URL of the Telegram Mini App (used for notification deep links)
MINI_APP_URL=https://fifawcforecastgame.vercel.app

# API-Football (api-sports) — server-only, used by import:player-photos script
# Free tier: https://dashboard.api-football.com/
API_FOOTBALL_KEY=

# Card photo imports (FIFARosters local card collection pipeline)
# CARD_PHOTOS_FIFAROSTERS_* — batch/limit/team filters for scrape:card-photos-fifarosters-local
# CARD_ROSTER_TEAMS=Brazil — team filter for build:card-roster-from-lineups and push:card-collection-local
# CARD_ROSTER_POOL_SIZE=15 — XI + up to 4 substitute-ins/bench extras per team
# CARD_COLLECTION_STUDIO_PORT=3847 — local Card Collection Studio HTTP port
# FIFAROSTERS_MANUAL_PICK=1 — disable auto-pick; all candidates go to picker HTML
# Local card collection workspace: scripts/output/card-collection/
# FIFAROSTERS_YEAR=26 — FUT game year for FifaRosters lookup
# FIFAROSTERS_API_DELAY_MS=1500 — polite delay between FifaRosters requests (use 1500+ for full export)
# FIFA_CARD_BACKGROUND_DIR=card_backgrounds — directory for fifa_{team}_bg.png backgrounds
# FIFA_CARD_BACKGROUND_PATH=fifa_card_background.png — generic fallback background
# FIFA_CARD_BG_REMOVAL_TOLERANCE=40 — flood-fill tolerance when stripping outer canvas
# FIFA_CARD_PLAYER_SCALE=0.85 — dynamic player render width scale on card composite
# FIFA_CARD_FACE_SCALE=0.72 — face headshot width scale (smaller than dynamic)
# FIFA_CARD_PLAYER_TOP=0.08 — minimum top offset for dynamic player render
# Dynamic renders auto-anchor at 76% height; face headshots anchor on gold divider at 58%.

# Match highlights sync (Supabase Edge Function secrets — not used by Next.js)
# Official FIFA YouTube channel: https://www.youtube.com/@FIFA
# Fallback until FIFA publishes: https://www.youtube.com/@sporttvportugal/videos
# (titles contain "Resumo:" or "Summary:"; auto-upgraded to FIFA when available)
YOUTUBE_API_KEY=
FIFA_YT_CHANNEL_ID=UCpcTrCXblq78GZrTUTLWeBw
# Optional override; defaults to resolving @sporttvportugal by handle
SPORTTV_YT_CHANNEL_ID=
