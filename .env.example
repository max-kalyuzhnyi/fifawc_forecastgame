# Supabase (get from project dashboard → Connect)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only: used by schedule import script (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Telegram Mini App (server-only — never expose to browser)
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Random secret for deriving Supabase passwords: openssl rand -hex 32
TELEGRAM_AUTH_PEPPER=your-random-pepper-here

# Dev only: auto sign-in when opened outside Telegram (defaults to 169900085)
DEV_TELEGRAM_ID=169900085
