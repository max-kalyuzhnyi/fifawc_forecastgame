{
  "name": "fifawc_forecastgame",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "portless run --name fifawc --force next dev",
    "dev:plain": "next dev",
    "proxy:start": "portless proxy start -p 1355 --no-tls",
    "proxy:start:https": "portless proxy start -p 1355",
    "proxy:stop": "portless proxy stop",
    "setup:https": "portless trust && portless proxy stop && portless proxy start -p 1355",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:schedule": "tsx scripts/import-schedule.ts",
    "extract:team-colors": "tsx scripts/extract-team-colors.ts"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "@tma.js/init-data-node": "^2.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "portless": "^0.14.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
