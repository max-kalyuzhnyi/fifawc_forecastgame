{
  "name": "fifawc_forecastgame",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "portless run --name fifawc --force next dev",
    "dev:plain": "next dev",
    "proxy:start": "portless proxy start -p 1355 --no-tls",
    "proxy:start:https": "portless proxy start -p 1355",
    "proxy:stop": "portless proxy stop",
    "setup:https": "portless trust && portless proxy stop && portless proxy start -p 1355",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:schedule": "tsx scripts/import-schedule.ts",
    "import:squads": "tsx scripts/import-squads.ts",
    "import:player-photos": "tsx scripts/import-player-photos.ts",
    "build:card-roster-from-lineups": "tsx scripts/build-card-roster-from-lineups.ts",
    "scrape:card-photos-fifarosters-local": "tsx scripts/scrape-card-photos-fifarosters-local.ts",
    "report:card-collection-studio": "tsx scripts/report-card-collection-studio.ts",
    "card-collection:studio": "tsx scripts/card-collection-studio.ts",
    "apply:card-photo-selections": "tsx scripts/apply-card-photo-selections.ts",
    "push:card-collection-local": "tsx scripts/push-card-collection-local.ts",
    "seed:cards": "tsx scripts/seed-cards.ts",
    "audit:card-photos": "tsx scripts/audit-card-photos.ts",
    "simulate:cards": "tsx scripts/simulate-card-economy.ts",
    "map:fd": "tsx scripts/map-football-data.ts",
    "extract:team-colors": "tsx scripts/extract-team-colors.ts",
    "broadcast:send": "tsx scripts/send-broadcast.ts",
    "broadcast:env:pull": "vercel env pull .env.broadcast.local --environment=production --yes && node scripts/patch-broadcast-env.mjs",
    "broadcast:send:prod": "npm run broadcast:env:pull && BROADCAST_ENV_FILE=.env.broadcast.local tsx scripts/send-broadcast.ts",
    "deploy": "vercel deploy --yes",
    "deploy:prod": "vercel deploy --prod --yes",
    "deploy:functions": "supabase functions deploy sync-live-matches send-goal-notifications send-pick-reminders send-broadcast sync-highlights --no-verify-jwt --project-ref qgawmjczgfbhwsdpsqly"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@supabase/ssr": "^0.12.0",
