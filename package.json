    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "sharp": "^0.34.5",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
